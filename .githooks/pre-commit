#!/bin/sh
# Pre-commit hook: reject commits that add assistant-style personal prompts to README files.
# Install by running: git config core.hooksPath .githooks

# Patterns that indicate a personal-facing prompt (case-insensitive)
BAD_PATTERNS="you are given|you are asked|your task|your goal|answer the following|please provide|please explain|explain why|respond to|tell me|you should"

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for file in $STAGED_FILES; do
  # Check common README filename variants
  case "$file" in
    *README*|*Readme*|*readme*)
      # Use git show to get the staged version of the file
      if git show :"$file" | grep -Ei "$BAD_PATTERNS" >/dev/null 2>&1; then
        echo "\nERROR: The staged README ($file) contains personal/assistant-style prompts."
        echo "This repository policy blocks adding questions or prompts addressed to a person (e.g. 'You are given...', 'Please provide', etc.) into README files."
        echo "Please remove such prompts or move them into a dedicated exercise/problem file before committing.\n"
        exit 1
      fi
      ;;
  esac
done

exit 0

